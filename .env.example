# ════════════════════════════════════════════════
# BEN AMI SHOP — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ════════════════════════════════════════════════

# Environnement : development | production
NODE_ENV=development

# Port d'écoute du serveur
PORT=3000

# Adresse d'écoute (0.0.0.0 = toutes les interfaces)
HOST=0.0.0.0

# Secret JWT — OBLIGATOIRE en production (min. 32 caractères aléatoires)
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Chemin vers la base SQLite (optionnel, défaut : ./benami_shop.db)
# DB_PATH=/data/benami_shop.db

# CORS : origine autorisée (laisser vide pour bloquer le CORS en prod)
# En développement, * est utilisé automatiquement
# CORS_ORIGIN=https://votre-domaine.com
