# ════════════════════════════════════════════════
# BEN AMI SHOP — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ════════════════════════════════════════════════

# Environnement : development | production
NODE_ENV=development

# Port d'écoute du serveur
PORT=3000

# Adresse d'écoute (0.0.0.0 = toutes les interfaces)
HOST=0.0.0.0

# Secret JWT — OBLIGATOIRE en production (min. 32 caractères aléatoires)
# Générer avec : node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# URL de connexion PostgreSQL — OBLIGATOIRE
# Format local    : postgresql://postgres:motdepasse@localhost:5432/benami_shop
# Format Render   : postgresql://user:pass@host/dbname?sslmode=require
# ⚠️  Encodez les caractères spéciaux dans le mot de passe (@→%40, #→%23, etc.)
DATABASE_URL=postgresql://user:password@host:5432/benami_shop

# CORS : origine autorisée (laisser vide pour bloquer en prod)
# CORS_ORIGIN=https://votre-app.onrender.com
